,{i,Keys[cyclogramValveDict]}];
}][[1]]

In[84]:=  GGAZ[P1_,P2_,Mu_, F_,T1_, k_,R_]:=Block[ {PIcrit,PI,GG,g0},
 If[P1>10^4,g0=1,g0=980.665];
PI = P2/P1;
PIcrit = (2/(k+1))^(k/(k-1));
	If[P1>P2,	      
	  If[PI < PIcrit,PI = PIcrit];		
	  GG=P1*Mu*F*\[Sqrt]((g0*(2 k )/(R T1(k-1)))((PI)^(2/k)-(PI)^((k+1)/k))),

	  GG=0];GG];

In[85]:=  FuncDpTurbOut[k_,p1_,p2_,q_]:=
Block[{f,PI,df,c},
PI=p2/p1;
f=((k+1)/2)^(2/(k-1))*(k+1)/(k-1)*(PI^(2/k)-PI^((k+1)/k))-q^2;
df=((k+1)/2)^(2/(k-1))*(k+1)/(k-1)*(2/k*PI^(2/k-1)-(k+1)/k*PI^((k+1)/k-1));
c=df/p1;
-f/c]

