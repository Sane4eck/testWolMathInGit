In[400]:= defConfinesAll[t_] := Block[{},
  {
   (*PRESSURE*)
   {po1, po2, po3, po4} = 
    Min[Max[#, pEnv(*interpPressureVaporFu[293]*)], pMax] & /@ {po1, po2, po3,
       po4};
   {pf1, pf2, pf3, pf4, pf5 , pf6, pf7} = 
    Min[Max[#, pEnv(*interpPressureVaporFu[293]*)], pMax] & /@ {pf1, pf2, pf3,
       pf4, pf5 , pf6, pf7};
   {pGg, pGv, pCh} = Min[Max[#, pEnv], pMax] & /@ {pGg, pGv, pCh};
   (*{po4}=Min[#,poB]&/@{po4};*)
   (*{pGg}=Max[Min[#,p3Fu],pEnv]&/@{pGg};*)
   (*VOLUME*)
   {DvolVf1xCh, DvolVo1xGg} = Max[#, 0] & /@ {DvolVf1xCh, DvolVo1xGg};
   {volVf1xCh} = Min[Max[#, 0], volVf1xChNom] & /@ {volVf1xCh};
   {volVo1xGg} = Min[Max[#, 0], volVo1xGgNom] & /@ {volVo1xGg};
   (*MASS FLOW*)
   {moTx1, mo2x3, mo3xGg, mo3x4(*,mo4xIc*)(*moBx4,*)(*mo4xIg*)} = 
    Max[#, 0] & /@ {moTx1, mo2x3, mo3xGg, mo3x4(*,mo4xIc*)(*moBx4,*)(*mo4xIg*)};
   {mfTx1, mf2xCh, mf3x4, mf4x6, mf4x5, mfBx7, mf7x5, mf5xIg,(*mf7x6,*)
     mf6xIc} = 
    Max[#, 0] & /@ {mfTx1, mf2xCh, mf3x4, mf4x6, mf4x5, mfBx7, mf7x5, 
      mf5xIg,(*mf7x6,*)mf6xIc};
   {mPmpOxOut, mPmp1FuOut, mPmp2FuOut} = {mo2x3 + mo2xTrbOut, 
     mf2xChFill + mf3x4 + mfChCool, mf3x4};
   {(*mo4xIg,*)mf5xIg, mf7x5} = Min[#, 200] & /@ {(*mo4xIg,*)mf5xIg, mf7x5};
   {mo4xIg, mf5xIg, mf7x5} = Max[#, -100] & /@ {mo4xIg, mf5xIg, mf7x5};
   (*OTHER*)
   {omega} = Max[#, 1] & /@ {omega};
   {xCVf1, xCVf2, xCVf3, xCVf4, xCVo1} = 
    Min[Max[#, 0], xFlapMax] & /@ {xCVf1, xCVf2, xCVf3, xCVf4, xCVo1};
   }]

