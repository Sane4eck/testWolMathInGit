defCalculatCoef[dict_] := Block[{return},
   {
    If[dict[[2]] == "-", Return[dict[[1]]]];
    If[dict[[2]] == "pressure", Return[dict[[1]]*\[Delta]P]];
    If[dict[[2]] == "density", Return[dict[[1]]*\[Delta]Rho]];
    If[dict[[2]] == "inertia", Return[dict[[1]]*\[Delta]J*10]];(*!!!!!!!!!!!!!!!!!!!!!!!*)
    If[dict[[2]] == "diameter", Return[dict[[1]]*\[Delta]D]];
    If[dict[[2]] == "area", Return[dict[[1]]*\[Delta]F]];
    If[dict[[2]] == "volume", Return[dict[[1]]*\[Delta]V]];
    If[dict[[2]] == "gas constant", Return[dict[[1]]*\[Delta]R]];
    If[dict[[2]] ==  "inertia turb", Return[dict[[1]]*\[Delta]Jinert]];
    If[dict[[2]] == "compliance", Return[dict[[1]]*\[Delta]C]];
    If[dict[[2]] == "resist cavitation", Return[dict[[1]]*\[Delta]Rkav]];
    If[dict[[2]] == "heat capacity", Return[dict[[1]]*\[Delta]Cp]];
    Return["\[LeftArrow]\[LeftArrow]\[LeftArrow] NoTyepeVarInExcel \[RightArrow]\[RightArrow]\[RightArrow]"]
    }][[1]]

