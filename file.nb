In[408]:= Prav[t_, y_] := Block[{
   (* Valve *)
   xCVf1, xCVf2, xCVf3, xCVf4, xCVo1,
   uCVf1, uCVf2, uCVf3, uCVf4, uCVo1,
   (* mass *)    
   masbf, masbo,               
   (* pressure *)
   pf1, pf4, pf5, pf6, pf7, poB, po1, po3, po4, pGg, pGv, pCh,
   (* mass flow rate *)
   mfTx1, mf2xCh, mf3x4, mf4x6, mf6xIc, mf4x5, mf5xIg, mfBx7, mf7x6, mf7x5, 
   moTx1, mo2x3, mo3xGg, mo2xGg, mo3x4, mo4xIc, mo4xIg, moBx4,
   (* volume *)
   volVf1xCh, volVo1xGg,
   (* Other *)
   omega
   }, {{
                xCVf1, xCVf2, xCVf3, xCVf4, xCVo1,
                uCVf1, uCVf2, uCVf3, uCVf4, uCVo1,    
                masbf, masbo,               
                pf1, pf4, pf5, pf6, pf7, poB, po1, po3, po4, pGg, pGv, pCh,
                mfTx1, mf2xCh, mf3x4, mf4x6, mf6xIc, mf4x5, mf5xIg, mfBx7, 
                mf7x6, mf7x5, moTx1, mo2x3, mo3xGg, mo2xGg, mo3x4, mo4xIc, 
                mo4xIg, moBx4,
                volVf1xCh, volVo1xGg,
                omega} = y;
              defConfinesAll[t];
              defConditionsAll[t];
              (* Зануляем производные *)
              {DxCVf1, DxCVf2, DxCVf3, DxCVf4, DxCVo1,
                DuCVf1, DuCVf2, DuCVf3, DuCVf4, DuCVo1,
                Dmasbf, Dmasbo,               
                Dpf1, Dpf4, Dpf5, Dpf6, Dpf7, DpoB, Dpo1, Dpo3, Dpo4, DpGg, 
                DpGv, DpCh,
                DmfTx1, Dmf2xCh, Dmf3x4, Dmf4x6, Dmf6xIc, Dmf4x5, Dmf5xIg, 
                DmfBx7, Dmf7x6, Dmf7x5, DmoTx1, Dmo2x3, Dmo3xGg, Dmo2xGg, 
                Dmo3x4, Dmo4xIc, Dmo4xIg, DmoBx4,
                DvolVf1xCh, DvolVo1xGg,
                Domega
                } = ConstantArray[0, Length[y]];
              (* Система уравнений *)
              iterRunge = iterRunge + 1;
              rpm = omega/\[Omega] // N;
              													(*! BALLONs !*)
              									(* Ballon Fu *)
              Dmasbf = -mfBx7;  (*DmasBall*)
              volfB = volfBNom - Abs[masbf]/rhofB;
              pfB = pfBNom(*If[volfB\[LessEqual] volfBNom*0.01,pEnv,pfBNom]*);
              									(* Ballon Ox *)
              poB = poBNom; ToB = ToBNom;
              koB = interpKOxygen[poB, ToB];
              ToB = ToB0*(poB/poBNom)^((koB - 1.)/koB); (* 
              Температура газа в баллоне *)
              voloB = voloBNom - Abs[masbo]/rhooB;
              Dmasbo = -(moBx4);(*DmasBall*)
              DpoB = 0(*-koB*RoB*ToB/voloBNom*(moBx4)*);(* 
              DpBall-производная dPb/dt *)
              
              													(*! Line FUEL !*)
              
              DmfTx1 = ((pfT - pf1 - rfTx1/rhoFu * Abs[mfTx1]* mfTx1)/
                 ifTx1);(* -Dm- *);
              mfChCool = mfChCoolNom*(mf2xCh/mf2xChNom);
              Dpf1 = (mfTx1 - mf2xCh - mfChCool - mf3x4)/Cfp1cav;(* -Dp- *);
             										(*! pump _1_ FU !*);
             
             HfPmp1 = FuncHPmp1Fu[mf2xCh + mfChCool + mf3x4, rhoFu, 
               omega/\[Omega]];
             cfCavPmp1R1Fu = 0;
             cfCavPmp1R2Fu = 0;
             inertRevPmp1Fu = 0;
             pf2 = pf1 + HfPmp1 *coefHfPmp1;
             {flagFillVf1xCh, flagValOpenVf1, Dmf2xCh, DvolVf1xCh, mf2xChFill,
                mf2xChJet} = 
              funcFilling[{flagFillVf1xCh, flagValOpenVf1}, t, 
               tVf11 < t <=  (tVf12 + dtVf12), volVf1xCh, volVf1xChNom, 
               "магістраль ПАЛЬНОГО на КЗ заповнена на: ", rVf1Nom, aVf1Max, 
               rf2xVf1, rfVf1xCh, if2xCVf1, ifCVf1xCh, pf2, pCh, mf2xCh, 
               rhoFu, intAVf1, 1, 4];
             										(*! pump _2_ FU !*);
             HfPmp2 = FuncHfPmp2[mf3x4, rhoFu, omega/\[Omega]];
             cfCavPmp2R1Fu = 0;
             cfCavPmp2R2Fu = 0;
             inertRevPmp2Fu = 0;
             pf3 = pf2 + HfPmp2 *coefHfPmp2;
             							(* Ділянка від Насоса2  *)
             
             Dmf3x4 = (pf3 - pf4 - (rf3x4/rhoFu)*Abs[mf3x4] *mf3x4)*(1/
                 if3x4);(*Dmf3x4*)
             
             rCVf2 = funcCheckValveCalcResisOtXCV01[xCVf2, coefRCVf2];
             rf4x6 = rf4xCVf2 + rCVf2 + rfCVf2x6;
             
             Dmf4x6 = (pf4 - pf6 - (rf4x6/rhoFu)*Abs[mf4x6]*mf4x6)*(1/
                 if4x6);(*Dmf4x6*)
             
             rVf3 = 1/(2*intAVf3[t]^2);
             rf6xIc = rf6xVf3 + rVf3;
             
             Dmf6xIc = (pf6 - pCh - (rf6xIc/rhoFu)*Abs[mf6xIc]*mf6xIc)*(1/
                 if6xIc);(*Dmf6xIc*)
             
             
             Dmf7x6 = (pf7 - pf6 - (rf7x6/rhoFu)*Abs[mf7x6]*mf7x6)*(1/
                 if7x6);(*Dmf7x6*)
             
             rCVf1 = funcCheckValveCalcResisOtXCV01[xCVf1, coefRCVf1];
             rf4x5 = rf4xCVf1 + rCVf1 + rfCVf1x5;
             
             Dmf4x5 = (pf4 - pf5 - (rf4x5 /rhoFu)*Abs[mf4x5]*mf4x5)*(1/
                 if4x5);(*Dmf4x5*)
             
             rVf2 = 1/(2*intAVf2[t]^2);
             rf5xIg = rf5xVf2 + rVf2;
             
             Dmf5xIg = (pf5 - pGg - (rf5xIg/rhoFu)*Abs[mf5xIg]*mf5xIg)*(1/
                 if5xIg);(*Dmf5xIg*)
             
             rCVf3 = funcCheckValveCalcResisOtXCV01[xCVf3, coefRCVf3];
             rfBx7 = rfBxCVf3 + rCVf3 + rfCVf3x7;
             
             DmfBx7 = (pfB - pf7 - (rfBx7/rhoFu)*Abs[mfBx7]*mfBx7)*(1/
                 ifBx7);(*DmfBx7*)
             
             rCVf4 = funcCheckValveCalcResisOtXCV01[xCVf4, coefRCVf4];
             rf7x5b = rf7xCVf4 +(*rCVf4+*)rfCVf4x5b;
             
             Dmf7x5 = (pf7 - pf5 - (rf7x5b /rhoFu)*Abs[mf7x5]*mf7x5)*(1/
                 if7x5);(*Dmf7x5*)
             
             Dpf4 = (mf3x4 - mf4x6 - mf4x5)*(1/Cf4)(*+coefEpsf4(Dmf3x4-Dmf4x6-
             Dmf4x5)*);(*Dpf4*)
             Dpf6 = (mf4x6 + mf7x6 - mf6xIc)*(1/Cf6)(*+coefEpsf6(Dmf4x6+
             Dmf7x6-Dmf6xIc)*);(*Dpf6*)
             Dpf5 = (mf4x5 + mf7x5 - mf5xIg)*(1/Cf5)(*+coefEpsf5(Dmf4x5+
             Dmf7x5-Dmf5xIg)*);(*Dpf5*)
             Dpf7 = (mfBx7 - mf7x6 - mf7x5)*(1/Cf7)(*+coefEpsf7(DmfBx7-Dmf7x6-
             Dmf7x5)*);(*Dpf7*)
             	(* AREA *)	
             defConditionsAll[t];
             	(* AREA CV01.2 (Ch) *)
             
             pCVf2In = 
              pf4 - (rf4xCVf2/rhoFu)*Abs[mf4x6]*mf4x6 - 
               If[mf4x6 > 0 , if4xCVf2, 0]*Dmf4x6;
             
             pCVf2Out = 
              
              pf6 + (rfCVf2x6/rhoFu)*Abs[mf4x6]*mf4x6 + 
               If[mf4x6 > 0, ifCVf2x6, 0]*Dmf4x6;
             {DxCVf2, DuCVf2, aCVf2(*,forceCVf2In,forceCVf2Out ,forceCVf2x,
               forceSprngCVf2,forceSumCVf2*)} = 
              funcCheckValveCV01[pCVf2In, pCVf2Out, uCVf2, xCVf2];		
             		(* AREA CV01.4 (Gg) *)
             
             pCVf1In = 
              pf4 - (rf4xCVf1/rhoFu)*Abs[mf4x5]*mf4x5 - 
               If[mf4x5 > 0, if4xCVf1, 0]*Dmf4x5;
             
             pCVf1Out = 
              pf5 + (rfCVf1x5/rhoFu)*Abs[mf4x5]*mf4x5 + 
               If[mf4x5 > 0, ifCVf1x5, 0]*Dmf4x5;
             {DxCVf1, DuCVf1, aCVf1(*,forceCVf1In,forceCVf1Out,forceCVf1x,
               forceSprngCVf1,forceSumCVf1*)} = 
              funcCheckValveCV01[pCVf1In, pCVf1Out, uCVf1, xCVf1];
             		(* AREA CV01.3 (Ball) *)
             
             pCVf3In = 
              pfB - (rfBxCVf3/rhoFu)*Abs[mfBx7]*mfBx7 - 
               If[mfBx7 > 0, ifBxCVf3, 0]*DmfBx7;
             
             pCVf3Out = 
              pf7 + (rfCVf3x7/rhoFu)*Abs[mfBx7]*mfBx7 + 
               If[mfBx7 > 0, ifCVf3x7, 0]*DmfBx7;
             {DxCVf3, DuCVf3, aCVf3(*,forseCVf3In,forseCVf3Out,forseCVf3x,
               forseSprngCVf3,forseSumCVf3*)} = 
              funcCheckValveCV01[pCVf3In, pCVf3Out, uCVf3, xCVf3];		
             		(* AREA CV01.5 (BallGg) *)
             
             pCVf4In = 
              pf7 - (rf7xCVf4/rhoFu)*Abs[mf7x5]*mf7x5 - 
               If[mf7x5 > 0, if7xCVf4, 0]*Dmf7x5;
             
             pCVf4Out = 
              pf5 + (rfCVf4x5b/rhoFu)*Abs[mf7x5]*mf7x5 + 
               If[mf7x5 > 0, ifCVf4x5, 0]*Dmf7x5;
             {DxCVf4, DuCVf4, aCVf4(*,forseCVf4In,forseCVf4Out ,forseCVf4x,
               forseSprngCVf4,forseSumCVf4*)} = 
              funcCheckValveCV01[pCVf4In, pCVf4Out, uCVf4, xCVf4];
             
             			(*! Line OXYGEN !*)
             (* Pump line *)
             
             DmoTx1 = ((poT - po1 - roTx1/rhoOx * Abs[moTx1]* moTx1)/
                ioTx1);(* -Dm- *);
             mo2xTrbOut = mo2xTrbOutNom*(mo2x3/mo2x3Nom);
             mPmpOutOx = mo2x3 + mo2xTrbOut;
             Dpo1 = (moTx1 - mo2x3 - mo2xTrbOut)/Cfp1cav;(* -Dp- *);
            												(* ! pump _OX ! *);
            HoPmp = FuncHoPmp[mo2x3 + mo2xTrbOut, rhoOx, omega/\[Omega]];
            (* Cavitation \[DownArrow] *)
            cfCavPmpR1Ox = 0;
            cfCavPmpR2Ox = 0;
            inertRevPmpOx = 0;
            po2 = po1 + HoPmp *coefHoPmp;
            
            (* Ballon line *)
            rVo2 = 1/(2*intAVo2[t]^2);
            roBx4 = roBxVo2 + rVo2 + roVo2x4;
            
            DmoBx4 = (poB - po4 - (roBx4/rhoOx)*Abs[moBx4]*moBx4)*(1/
                ioBx4);(*DmfBx7*)
            
            rVo3 = 1/(2*intAVo3[(*0*)t]^2);
            ro4xIg = ro4xVo3 + rVo3 + roVo3xIg;
            
            Dmo4xIg = (po4 - pGg - ro4xIg/rhoOx*Abs[mo4xIg]*mo4xIg)*(1/
                io4xIg);(* (10*10^5(*po4*)-1*10^5(*pGg*)-((*ro4xIg*)(*ro4xIg*)
            1/10(*rhoOx*))*(*Abs[mo4xIg]**)1(*mo4xIg*))(**(1/
            io4xIg)*);(*Dmf4xIg*)*)
            
            rVo4 = 1/(2*intAVo4[t]^2);
            ro4xIc = ro4xVo4 + rVo4 + roVo4xIc;
            
            Dmo4xIc = (po4 - pCh - (ro4xIc/rhoOx)*Abs[mo4xIc]*mo4xIc)*(1/
                io4xIc);(*Dmf4xIg*)
            
            If[flagFillVo1xGg == 0,
             
             (* Filling \[DownArrow] *)
             {flagFillVo1xGg, flagValOpenVo1, Dmo2xGg, DvolVo1xGg, mo2xGgFill,
                mo2xGgJet} = 
              funcFilling[{flagFillVo1xGg, flagValOpenVo1}, t, 
               tVo11 < t <=  (tVo12 + dtVo12), volVo1xGg, volVo1xGgNom, 
               "Тракт ОКИСЛИТЕЛЯ до GG заполнен на ", rVo1Nom, aVo1Max, 
               ro2xVo1, roVo1x3 + ro3xGg, io2xVo1, ioVo1x3 + io3xGg, po2, pGg,
                mo2xGg, rhoOx, intAVo1, 1, 8];
             {mo2x3, mo3xGg} = {mo2xGgFill, mo2xGgJet};
             {Dmo2x3, Dmo3xGg, Dmo3x4} = {Dmo2xGg, Dmo2xGg, 0};
             Dpo3 = 0;
             Dpo4 = (moBx4 - mo4xIg - mo4xIc)/Co4;(* -Dp- *);
             mo3xTrbIn = 0;,
             
             rVo1 = 1/(2*intAVo1[t]^2);
             ro2x3 = ro2xVo1 + rVo1 + roVo1x3;
             
             Dmo2x3 = (po2 - po3 - (ro2x3/rhoFu)*Abs[mo2x3]*mo2x3)*(1/
                 io2x3);(*Dmo2x3*)
             
             Dmo3xGg = (po3 - pGg - (ro3xGg/rhoFu)*Abs[mo3xGg]*mo3xGg)*(1/
                 io3xGg);(*Dmo3xGg*)
             rCVo1 = funcCheckValveCalcResisOtXCV01[xCVo1, coefRCVo1];
             ro3x4 = ro3xCVo1 + rCVo1 + roCVo1x4;
             
             Dmo3x4 = (po3 - po4 - (ro3x4/rhoFu)*Abs[mo3x4]*mo3x4)*(1/
                 io3x4);(*Dmo3xGg*)
             Dpo3 = (mo2x3 - mo3xGg - mo3x4)/Co3;
             Dpo4 = (moBx4 + mo3x4 - mo4xIg - mo4xIc)/Co4;(* -Dp- *);
             Dmo2xGg = Dmo3xGg;
             {mo2xGgFill, mo2xGgJet} = {mo3xGg, mo3xGg};
             mo3xTrbIn = mo3xTrbInNom*(mo3xGg/mo3xGgNom);
             
             		(* AREA CV01.6-7 (Ox) *)
             
             pCVo1In = 
              po3 - (ro3xCVo1/rhoFu)*Abs[mo3x4]*mo3x4 - 
               If[mo3x4 > 0, io3xCVo1, 0]*Dmo3x4;
             
             pCVo1Out = 
              po4 + (roCVo1x4/rhoFu)*Abs[mo3x4]*mo3x4 + 
               If[mo3x4 > 0, ioCVo1x4, 0]*Dmo3x4;
             {DxCVo1, DuCVo1, aCVo1(*,forseCVo1In,forseCVo1Out ,forseCVo1x,
               forseSprngCVo1,forseSumCVo1*)} = 
              funcCheckValveCV01[pCVo1In, pCVo1Out, uCVo1, xCVo1];
             ];
            
            	;(* GG *);
           	moGg = Max[mo2xGgJet + mo4xIg, 0]; mfGg = Max[mf5xIg, 1*10^-10];   
           	moCh = Max[moGg + mo4xIc + mo2xTrbOut + mo3xTrbIn, 0]; 
           mfCh = Max[mf5xIg + mf6xIc + mfChCool + mf2xChJet, 1*10^-10];   
             If[flagBurnGg == 1 && flagBurnGgSTOP == 0, 
            	 kmGg = Max[Min[moGg/mfGg, 499], 1*10^-4];
            	RGg    = interpROxygenJetaGg[pGg, kmGg]*\[Delta]R;         
            	TGg    = Max[interpTOxygenJetaGg[pGg, kmGg], TEnv];               
            	kGg    = interpKOxygenJetaGg[pGg, kmGg];
            
            	If[t <= tBurnGg + 0.15, TGg = Max[TEnv, TGg/3]];
            	RGv = RGg; kGv = kGg; 
            TGv = Max[TEnv, TGg*(pGv /pGg)^((kGg - 1)/kGg)];
            	
            pTrbIn = dztaTrb^2* \[Sqrt]Max[(pGg^2 - 
                  kGg*RGg*TGg*(moGg + mfGg + mo3xTrbIn)^2), 1];
            	mGg = GGAZ[pGg, pGv,  muGg,  fGg1, TGg,  kGg,  RGg];
            	mGv = GGAZ[pGv, pCh,  muGv,  fGv1, TGv,  kGv,  RGv];
            	DpGg = ((RGg*TGg)/VGg)*(moGg + mfGg + mo3xTrbIn - mGg);
            	DpGv = ((RGv*TGv)/VGv)*(mGg + mo2xTrbOut - mGv),  
            
            	mGg = 0; mGv = 0;
            	kmGg = 0;
            	kGg = 1.4;(*************)
            	RGg = 287*\[Delta]R;(*************)
            	TGg = TEnv;
            	DpGg = 0;
            	DpGv = 0;
            	DpCh = 0;
            ];
           		;(* dynamic TNA *);(*mLeakOxNom,mLeakFu1Nom,mLeakFu2Nom*)
         								;(* pumpFu1 *);
        mfLeakP1 = mLeakFu1Nom*(rpm/rpmNom); 
        etaPmp1Fu = 
         FuncEtaPmpFu1[mf2xCh + mfChCool + mf3x4, rhoPmp1FuNom, 
          omega/\[Omega]];
        If[etaPmp1Fu > etaPmp1FuNom*0.01,
         mPmp1FuPow = mf2xCh + mfChCool + mf3x4,
         mPmp1FuPow = mfLeakP1; etaPmp1Fu = 1];
        If[etaPmp1Fu > 10^-4,
          torqPmp1Fu = 1/omega*pf2*mPmp1FuPow/(rhoPmp1FuNom*etaPmp1Fu),
          torqPmp1Fu = 0
         ];
        								;(* pumpFu2 *);
       mfLeakP2 = mLeakFu2Nom*(rpm/rpmNom); 
       etaPmp2Fu = FuncEtaPmpFu2[mf3x4, rhoPmp2FuNom, omega/\[Omega]];
       If[etaPmp2Fu > etaPmp2FuNom*0.1,
        mPmp2FuPow = mf3x4;,
        mPmp2FuPow = mfLeakP2; etaPmp2Fu = 1;];
       If[etaPmp2Fu > 10^-4,
         torqPmp2Fu = 1/omega*pf3*mPmp2FuPow/(rhoPmp2FuNom*etaPmp2Fu),
         torqPmp2Fu = 0
        ];
       								;(* pumpOx *);
      moLeakP1 = (mLeakOxNom)*(rpm/rpmNom); 
      etaPmpOx = FuncEtaPmpOx[mo2x3 + mo2xTrbOut, rhoPmpOxNom, omega/\[Omega]];
       If[etaPmpOx > etaPmpOxNom*0.01,
       mPmpOxPow = mo2x3 + mo2xTrbOut,
       mPmpOxPow = moLeakP1; etaPmpOx = 1];
      If[etaPmpOx > 10^-4,
        torqPmpOx = 1/omega*po2*mPmpOxPow/(rhoPmpOxNom*etaPmpOx), (* 
       Момент насоса Subscript[M, но]=(Subscript[P, но]\[CenterDot]Subscript[
       Overscript[m, .], но])/(\[Omega]\[CenterDot]Subscript[\[Rho], 
       о]\[CenterDot]Subscript[\[Eta], но]) *)
        torqPmpOx = 0
       ];
      								;(* Trbine *);
    (* Турбина Основная *);
    torqTrb = 0;
    etaTrb = 0;
    LadTrb = 0; 
    If[ flagBurnGg == 1 && pTrbIn >= pGv, 
     	PITrb = pGv/pTrbIn;
        LadTrb = kGg/(kGg - 1.)*RGg*TGg*(1. - (PITrb)^((kGg - 1.)/kGg));
        uTrb = Pi*DTrb*omega/\[Omega]/60.;
               cadTrb = Sqrt[2.*g0*LadTrb];
     If[cadTrb > 10^-6,
      etaTrb = FuncEtaTrb[uTrb/cadTrb];
           If[etaTrb < 0., etaTrb = 0.]
       ];
     ];
    torqTrb = 1/omega*mGv*LadTrb*etaTrb*coefTorqTrb; 	
    (* Domega *);
    Domega = (torqTrb - torqPmpOx - torqPmp1Fu - torqPmp2Fu)*g0/JTrbPmp ;
    		;(* Chamber *);
   If[flagBurnCh == 1 && flagBurnChSTOP == 0,    
    	 kmCh = Max[Min[mChOx/mChFu, 99], 1*10^-4];
    	RCh    = interpROxygenJetaCh[pCh, kmCh]*\[Delta]R;         
    	TCh    = interpTOxygenJetaCh[pCh, kmCh];               
    	kCh    = interpKOxygenJetaCh[pCh, kmCh];
    	mCh = GGAZ[pCh, pEnv, muThCh, aThChcorect, TCh, kCh,  RCh];
    	DpCh = ((RCh*TCh)/VCh)*(mGv + mo4xIc + mf6xIc + mf2xCh + mfChCool - mCh);,  
    
    	mCh = 0;
    	kmCh = 0;
    	kCh = 1.4;(*************)
    	RCh = 287*\[Delta]R;(*************)
    	TCh = TEnv;
    	DpCh = 0;
    ];
   
   defCorrection[t];(* ************ *);
   defConfinesAll[t];
   defConditionsAll[t];
   
   {DxCVf1, DxCVf2, DxCVf3, DxCVf4, DxCVo1,
    DuCVf1, DuCVf2, DuCVf3, DuCVf4, DuCVo1,
    Dmasbf, Dmasbo,               
    Dpf1, Dpf4, Dpf5, Dpf6, Dpf7, DpoB, Dpo1, Dpo3, Dpo4, DpGg, DpGv, DpCh,
    DmfTx1, Dmf2xCh, Dmf3x4, Dmf4x6, Dmf6xIc, Dmf4x5, Dmf5xIg, DmfBx7, Dmf7x6,
     Dmf7x5, DmoTx1, Dmo2x3, Dmo3xGg, Dmo2xGg, Dmo3x4, Dmo4xIc, Dmo4xIg, 
    DmoBx4,
    DvolVf1xCh, DvolVo1xGg,
    Domega}
   }]

