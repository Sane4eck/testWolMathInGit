],
ListLinePlot[
Transpose[{dict2["1_time"],dict2[key]}],PlotRange->Full,PlotStyle-> Directive[Thickness[thickness[[2]]],colorLine[[2]],Dashed(*RGBColor[1.,0.94,0.14]*)]
],PlotRange-> All],
{key,keys}];
