In[322]:= defCreateEqPipLine[listNameTXTnodes_, typeEquation_] := 
 Block[{result, equation, name1, name2, component, nameVar, resis, m, inert, 
    Dm, rho, p1, p2, elif, name, nameMassFlow}, {
    result = Reap[Do[
         name1 = ToString[i[[1]]];
         name2 = ToString[i[[2]]];
         component = ToString[i[[3]]];
         
         nameVar = component <> name1 <> "x" <> name2;
         resis = "r" <> nameVar;
         m = "m" <> nameVar;
         inert = "i" <> nameVar;
         Dm = "Dm" <> nameVar;
         rho = 
          If[component == "o", "rhoOx", 
           If[component == "f", "rhoFu"]](*component*);
         p1 = "p" <> component <> name1;
         p2 = 
          If[name2 == "Ic" || name2 == "Ch", "pCh", 
           If[name2 == "Ig" || name2 == "Gg", "pGg", 
            "p" <> component <> name2]] ;
         
         If[typeEquation == "Dm",
          
          equation = 
            Dm <> " =((" <> p1 <> "-" <> p2 <> "-" <> resis <> "/" <> rho <> 
             " * Abs[" <> m <> "]* " <> m <> ")/" <> inert <> ")";];
         If[typeEquation == "resis",
           
          equation = 
           resis <> " =Abs[((" <> p1 <> "-" <> p2 <> ")*" <> rho <> "/" <> m <>
             "^2)]"];
         
         Sow[equation];
         , {i, listNameTXTnodes}];][[2]];
    result
    }][[1, 1]]

In[323]:= defCreateEqVlvLine[listNameTXTnodes_, typeEquation_] := 
 Block[{result, equation1, equation2, equation3, name1, name2, name3, 
    component, nameVar1, nameVar2, nameVar3, resis1, resisValve, resis2, m, 
    inert, Dm, rho, p11, p12, p21, p22, elif, name, nameMassFlow}, {
    result = Reap[Do[
         name1 = ToString[i[[1]]];
         name2 = ToString[i[[2]]];
         name3 = ToString[i[[3]]];
         component = ToString[i[[4]]];
         
         nameVar1 = component <> name1 <> "x" <> name2;
         nameVar2 = component <> name2 <> "x" <> name3;
         nameVar3 = component <> name1 <> "x" <> name3;
         resis1 = "r" <> nameVar1;
         resisValve = "r" <> name2;
         resis2 = "r" <> nameVar2;
         m = "m" <> nameVar3;
         inert = "i" <> nameVar3;
         rho = If[component == "o", "rhoOx", If[component == "f", "rhoFu"]];
         
         p11 = "p" <> component <> name1;
         p12 = "p" <> name2 <> "In"; ;
         
         p21 = "p" <> name2 <> "Out";
         p22 = 
          If[name3 == "Ic" || name3 == "Ch", "pCh", 
           If[name3 == "Ig" || name3 == "Gg", "pGg", 
            "p" <> component <> name3]] ;
         
         If[typeEquation == "resis",
           
          equation1 = 
           resis1 <> " =((" <> p11 <> "-" <> p12 <> ")*" <> rho <> "/" <> m <>
             "^2)";
          
          equation2 = 
           resisValve <> " =((" <> p12 <> "-" <> p21 <> ")*" <> rho <> "/" <> 
            m <> "^2)";
           
          equation3 = 
           resis2 <> " =((" <> p21 <> "-" <> p22 <> ")*" <> rho <> "/" <> m <>
             "^2)"];
         Sow[{equation1, equation2, equation3}];
         , {i, listNameTXTnodes}];][[2]];
    result
    }][[1, 1]]

