In[82]:=  FKL[f1_,f2_,t1_,t2_,dt1_,dt2_,t_]:=
Block [{f},If[t<t1||t>=t2+dt2, f=f1];
If[t1<=t<(t1+dt1), f=f1+(f2-f1)*(t-t1)/dt1];
If[(t1+dt1)<=t<t2, f=f2];
If[t2<=t<(t2+dt2), f=f2-(f2-f1)*(t-t2)/dt2];
f]

