In[149]:= defLinearLaw[t_, valZero_, valNom_, t1_, t2_] := Block[{omega, rpm},
  rpm = If[t <= t1, valZero, 
    If[t <= t2, valZero + (valNom - valZero)/(t2 - t1)*(t - t1), valNom]];
  omega = rpm (*\[Omega]*);
  rpm]



