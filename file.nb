In[317]:= defSortList[ImportList_] := Block[{listii, result}, {
    result = {};
    Do[listii = {};
     Do[
      If[ToString[Head[ImportList[[i, j]]]] ==  ToString[Real],
       AppendTo[listii, Round[ImportList[[i, j]]]],
       AppendTo[listii, ImportList[[i, j]]]],
      {j, Length[ImportList[[1]]]}]; 
     AppendTo[result, listii], {i, Length[ImportList]}];
    result
    }][[1]]

